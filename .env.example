# Supabase — copy to .env and fill in (see docs/PLAYBOOK.md → Phase 2).
# @nuxtjs/supabase reads these two names automatically.
# Use the Project URL + the publishable (sb_publishable_…) or legacy anon key.
# NEVER put the secret / service_role key here — it bypasses RLS.
SUPABASE_URL=
SUPABASE_KEY=
